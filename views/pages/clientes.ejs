<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head', { title: 'Clientes' }) %>
</head>
<body class="container">
  <%- include('../partials/header') %>

  <main class="table-container">
    <h1>Clientes</h1>
    <a class="btn btn-primary mb-3" href="/">Volver al inicio</a>

    <% if (clientes.length === 0) { %>
      <div class="alert alert-info">No hay clientes registrados.</div>
    <% } else { %>
      <div class="table-responsive">
        <table id="clientesTable" class="table table-striped table-hover">
          <thead class="table-dark">
            <tr>
              <th>Nombre</th>
              <th>Email</th>
              <th>Teléfono</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% clientes.forEach(function(cliente) { %>
              <tr>
                <td><%= cliente.nombre %></td>
                <td><%= cliente.email %></td>
                <td><%= cliente.telefono || '-' %></td>
                <td>
                  <button class="btn btn-sm btn-primary" data-action="ver" data-id="<%= cliente._id %>">Ver</button>
                  <button class="btn btn-sm btn-secondary" data-action="editar" data-id="<%= cliente._id %>">Editar</button>
                  <button class="btn btn-sm btn-danger" data-action="borrar" data-id="<%= cliente._id %>" data-nombre="<%= cliente.nombre %>">Borrar</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>

  <%- include('../partials/modales-clientes') %>
  <%- include('../partials/footer') %>
  
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.datatables.net/2.2.2/js/dataTables.js"></script>
  <script src="https://cdn.datatables.net/2.2.2/js/dataTables.bootstrap5.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/clientes.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      new DataTable('#clientesTable', {
        pagingType: 'simple_numbers',
        language: {
          url: 'https://cdn.datatables.net/plug-ins/2.2.2/i18n/es-ES.json',
        }

      });
    });
  </script>
</body>
</html>